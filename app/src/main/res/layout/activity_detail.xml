<?xml version="1.0" encoding="utf-8"?>
<!-- Layout untuk halaman detail jaringan WiFi -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_secondary">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarDetail"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/bg_secondary"
            app:navigationIconTint="@color/text_primary"
            app:titleTextColor="@color/text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header Card: SSID + Status -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_wifi_logo"
                        android:tint="@color/md_theme_primary"
                        android:contentDescription="WiFi" />

                    <TextView
                        android:id="@+id/tvDetailSsid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="HomeNetwork_5G" />

                    <TextView
                        android:id="@+id/tvDetailBssid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        tools:text="AA:BB:CC:DD:EE:FF" />

                    <!-- Chip connected -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipConnected"
                        style="@style/Widget.Material3.Chip.Assist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="● Terhubung"
                        android:textColor="@color/signal_excellent"
                        app:chipBackgroundColor="@color/bg_primary"
                        app:chipStrokeColor="@color/signal_excellent"
                        app:chipStrokeWidth="1dp"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Sinyal -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📶  Kekuatan Sinyal"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvDetailSignalPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/signal_excellent"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            tools:text="85%" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/progressDetailSignal"
                                android:layout_width="match_parent"
                                android:layout_height="8dp"
                                android:max="100"
                                android:progress="85"
                                app:indicatorColor="@color/signal_excellent"
                                app:trackColor="@color/progress_track"
                                app:trackCornerRadius="4dp" />

                            <TextView
                                android:id="@+id/tvDetailSignalQuality"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"
                                tools:text="Sangat Kuat ●●●●" />

                            <TextView
                                android:id="@+id/tvDetailStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                tools:text="Tidak Terhubung" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/divider_color" />

                    <!-- dBm detail -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Level sinyal (RSSI)"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tvDetailSignalDbm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="-45 dBm" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Jaringan -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📡  Informasi Jaringan"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                    <!-- Frekuensi -->
                    <include layout="@layout/item_detail_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"/>

                    <!-- Semua row diisi programmatically via include + ID, tapi kita buat manual -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="12dp" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Frekuensi"
                            android:textColor="@color/text_secondary" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvDetailFrequency" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/text_primary"
                            android:textSize="13sp" android:textStyle="bold" tools:text="5180 MHz"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginVertical="10dp" android:background="@color/divider_color"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Channel"
                            android:textColor="@color/text_secondary" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvDetailChannel" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/text_primary"
                            android:textSize="13sp" android:textStyle="bold" tools:text="36"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginVertical="10dp" android:background="@color/divider_color"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Band"
                            android:textColor="@color/text_secondary" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvDetailBand" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/text_primary"
                            android:textSize="13sp" android:textStyle="bold" tools:text="5 GHz"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Keamanan -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒  Keamanan"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="12dp" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Protokol"
                            android:textColor="@color/text_secondary" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvDetailSecurity" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/security_wpa2"
                            android:textSize="14sp" android:textStyle="bold" tools:text="WPA2"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginVertical="10dp" android:background="@color/divider_color"/>

                    <TextView
                        android:id="@+id/tvDetailSecurityInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingMultiplier="1.4"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        tools:text="WPA2 menggunakan enkripsi AES-CCMP yang kuat." />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginVertical="10dp" android:background="@color/divider_color"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Capabilities"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvDetailCapabilities"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@color/bg_primary"
                        android:fontFamily="monospace"
                        android:padding="8dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        tools:text="[WPA2-PSK-CCMP][WPS][ESS]" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Disclaimer card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider_color"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="ℹ️  Data ini bersumber dari Android WiFi API resmi. Aplikasi tidak mengakses password atau data privat pengguna lain."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
